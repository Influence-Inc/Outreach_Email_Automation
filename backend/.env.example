# Server
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/influence_outreach

# Google OAuth (create at https://console.cloud.google.com/)
# Scopes required: https://www.googleapis.com/auth/gmail.send, gmail.readonly
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Sender identity (must match the authorized Google account)
SENDER_EMAIL=jennifer@useinfluence.xyz
SENDER_NAME=Jennifer

# Scheduler
FOLLOWUP_DELAY_HOURS=48
SCHEDULER_INTERVAL_MINUTES=15

# Upstream brands + campaigns source
# GET https://campaigns.influence.technology/api/bot/campaigns with x-bot-token header
CAMPAIGNS_API_BASE=https://campaigns.influence.technology
CAMPAIGNS_API_TOKEN=

# Optional: Instagram sessionid cookie from Jennifer's logged-in browser.
# Required to read business_email (the "Email" button data) for most profiles.
# Get it from Chrome: DevTools -> Application -> Cookies -> instagram.com -> sessionid
IG_SESSION_COOKIE=

# --- Creator negotiation ---------------------------------------------------
# Claude is used ONLY to (a) understand plain-text replies and (b) write the
# emails. Offer numbers are 100% formula (see pricing.js).
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Pricing formula constants. effectiveCpm = TARGET_CPM * (1 - RISK_BUFFER).
TARGET_CPM=15
RISK_BUFFER=0.20
BONUS_PERCENTAGE=0.20
NUM_VIDEOS=2

# Admin approval gate: no offer email sends until an admin approves an offer.
REQUIRE_OFFER_APPROVAL=true

# Negotiation follow-ups: bump after N idle days, at most this many, then CLOSED.
NEGOTIATION_FOLLOWUP_DAYS=2
NEGOTIATION_MAX_FOLLOWUPS=2

# Brand / manager / deadline fallbacks (per-campaign values win when present).
# MANAGER_NAME defaults to SENDER_NAME.
BRAND_NAME=
MANAGER_NAME=
CAMPAIGN_DEADLINE=the end of the month

# Set to 1/true to log negotiation emails instead of sending them (dry-run).
DRY_RUN=
