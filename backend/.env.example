# Server
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/influence_outreach

# Scheduler — how often the negotiation poller runs (outreach + follow-ups
# are sent by Instantly on its own schedule).
SCHEDULER_INTERVAL_MINUTES=5

# Pre-send email verification (syntax + DNS/MX). On by default; undeliverable
# scraped addresses are skipped and flagged 'invalid_email' instead of being
# pushed into Instantly. Set EMAIL_VERIFY=0 to disable.
EMAIL_VERIFY=1

# Off-Instagram email enrichment. When a profile has no email anywhere on
# Instagram, follow the creator's OWN links (website + Linktree/bio-hub links
# the extension captured) and scrape a verified contact email off those pages.
# Free + best-effort, on by default; set EMAIL_ENRICH=0 to disable the automatic
# fallback during scraping (the explicit POST /api/creators/:id/enrich-email and
# /api/creators/bulk/enrich-email endpoints still run on demand).
EMAIL_ENRICH=1
# Optional paid fallback, tried only when the free web discovery finds nothing.
# Off unless a provider + key are set. Supported values:
#   serper  — web search via serper.dev (set SERPER_API_KEY). Searches the
#             creator's name/handle for their email/contact — YouTube first (most
#             creators publish a business email on their channel About page) —
#             reads an address out of the result snippets, and scrapes the top
#             result pages (YouTube channel/About, company site, press, …),
#             including the channel's /about tab. Works even when the creator has
#             no site or link in bio. Only keeps an address that carries the
#             creator's own name/handle. Get a key at https://serper.dev.
#   hunter  — api.hunter.io email-finder (set HUNTER_API_KEY). Looks up a mailbox
#             on a specific domain, so it only runs when the creator has a site.
# Leave EMAIL_ENRICH_PROVIDER blank to never make a paid call.
EMAIL_ENRICH_PROVIDER=serper
SERPER_API_KEY=
HUNTER_API_KEY=

# Per-creator pacing between bulk lead-add calls to Instantly (ms). Jittered ±20%.
SEND_PACING_MS=60000

# Signatory shown in outreach + follow-up email bodies (the {SENDER_NAME}
# substitution in the built-in templates). Also used as a fallback for
# MANAGER_NAME if that isn't set.
SENDER_NAME=Jennifer

# Upstream brands + campaigns source
# GET https://campaigns.influence.technology/api/bot/campaigns with x-bot-token header
CAMPAIGNS_API_BASE=https://campaigns.influence.technology
CAMPAIGNS_API_TOKEN=

# Optional: Instagram sessionid cookie from Jennifer's logged-in browser.
# Required to read business_email (the "Email" button data) for most profiles.
# Get it from Chrome: DevTools -> Application -> Cookies -> instagram.com -> sessionid
IG_SESSION_COOKIE=

# --- Instantly.ai (email sender) ------------------------------------------
# All outreach, follow-ups, and negotiation replies go through Instantly.
# API key from https://app.instantly.ai/app/settings/integrations
INSTANTLY_API_KEY=
# Fallback Instantly campaign UUID. Each dashboard campaign can set its own
# Instantly campaign ID (Campaign settings → "Instantly campaign ID") so every
# brand uses its own outreach copy + follow-up sequence. This env value is used
# only for campaigns that haven't been mapped. Copy a UUID from the campaign URL
# in the Instantly dashboard.
INSTANTLY_CAMPAIGN_ID=
# HMAC secret to verify Instantly webhook signatures. Set this in the
# Instantly webhook config to reject forged payloads.
#
# Point the Instantly webhook at POST {PUBLIC_BASE_URL}/webhook/instantly and
# subscribe to BOTH events:
#   • Reply Received  — drives reply detection → negotiation (status: replied)
#   • Email Sent      — advances the dashboard from "outreach sent" to
#                       "follow up sent" when Instantly sends a follow-up step.
# Without the Email Sent event the status stays on "outreach sent" even after
# the follow-up goes out.
INSTANTLY_WEBHOOK_SECRET=
# Optional: per-request timeout for Instantly API calls (ms). Default 15000.
INSTANTLY_TIMEOUT_MS=
# Optional fallback sending mailbox (eaccount) for threaded negotiation replies.
# Normally the mailbox is captured automatically from each reply webhook
# (email_account). This is only used for replies received before that field was
# stored. Must be a connected Instantly account, e.g. jennifer@frominfluence.com
INSTANTLY_EACCOUNT=

# --- Creator negotiation ---------------------------------------------------
# Claude is used ONLY to (a) understand plain-text replies and (b) write the
# emails. Offer numbers are 100% formula (see pricing.js).
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Pricing formula constants. effectiveCpm = TARGET_CPM * (1 - RISK_BUFFER).
TARGET_CPM=15
RISK_BUFFER=0.20
BONUS_PERCENTAGE=0.20
NUM_VIDEOS=2

# Admin approval gate: no offer email sends until an admin approves an offer.
REQUIRE_OFFER_APPROVAL=true

# Negotiation follow-ups: bump after N idle days, at most this many, then CLOSED.
NEGOTIATION_FOLLOWUP_DAYS=2
NEGOTIATION_MAX_FOLLOWUPS=2

# Brand / manager / posting cadence. The campaign's own brand_name wins over
# BRAND_NAME. MANAGER_NAME is the signatory shown in negotiation emails.
BRAND_NAME=
MANAGER_NAME=Jennifer
# Posting cadence / timeline guidance, e.g. "1-2 videos per week". Claude (or
# the deterministic fallback) derives an approximate "all videos posted by"
# date from this cadence + today's date + the number of videos in the deal —
# it is NOT a literal date. CONTENT_CADENCE wins if both are set.
CAMPAIGN_DEADLINE=1-2 videos per week
CONTENT_CADENCE=

# --- Continuous reply learning ---------------------------------------------
# The negotiation model "learns" by collecting labeled (creator inbound →
# manager reply) pairs into the reply_examples table and replaying the most
# relevant ones as few-shot examples in every Claude prompt. Two feeds:
#
# 1. Delegate replies — every reply a human sends from the Delegate window is
#    labeled and stored immediately, so the same doubt/question stops landing
#    in the Delegate queue. Set LEARN_FROM_DELEGATE=0 to disable.
LEARN_FROM_DELEGATE=1
# 2. Mailbox harvest — every LEARN_HARVEST_HOURS the scheduler sweeps the
#    connected mailbox (jennifer@useinfluence.xyz) through the Instantly API,
#    pairs each creator message with the next manager reply, labels the pair
#    with Claude, and stores it. 0 disables the scheduled sweep (the manual
#    `npm run learn:harvest` CLI still works).
LEARN_HARVEST_HOURS=24
# Cap on mailbox emails scanned per harvest run (newest first).
LEARN_HARVEST_MAX_EMAILS=500
# The mailbox address whose messages count as "ours" when pairing threads.
# Falls back to INSTANTLY_EACCOUNT when unset.
SENDER_EMAIL=jennifer@useinfluence.xyz

# --- Creator Contracts -----------------------------------------------------
# When a creator accepts, a unique contract is generated and emailed as
# {PUBLIC_BASE_URL}/contract/{token} (PUBLIC_BASE_URL is set at the top of this
# file). In production, set PUBLIC_BASE_URL=https://campaigns.influence.technology
# — that service proxies /contract/:token, /contract.js and /api/contracts/*
# straight through to this backend (see its OUTREACH_BASE_URL env var), so the
# link the creator gets carries the campaigns.influence.technology domain while
# this backend still does all the actual work. This backend also still serves
# /contract/:token (and the legacy /contracts/:token) directly, so a bare
# PUBLIC_BASE_URL pointing at this service's own origin works too (e.g. local
# dev, or if the proxy isn't set up yet).
#
# Creator Database sync: after a contract is signed the creator + contract are
# pushed to the Creator-Database service (which dedups by email → instagram →
# name). CREATOR_DB_URL is that service's base URL; leave blank to disable the
# sync (the signature still records locally and a scheduler pass can retry).
# CREATOR_DB_API_KEY must match the Creator DB's INTERNAL_API_KEY — it's sent as
# the x-api-key header.
# To backfill contracts that were signed BEFORE this was configured, either:
#   • run once:  npm run sync:contracts           (add --dry-run to preview), or
#   • trigger over HTTP (no shell needed):
#       POST /api/bot/sync-contracts?dryRun=true   with x-bot-token: OUTREACH_BOT_TOKEN
#     (drop dryRun to actually push). Set OUTREACH_BOT_TOKEN to use this route.
CREATOR_DB_URL=
CREATOR_DB_API_KEY=
# Optional: per-request timeout for Creator-DB calls (ms). Default 15000.
CREATOR_DB_TIMEOUT_MS=

# Campaign dashboard sync: after a contract is signed, the creator + agreed
# deliverables/deadline are pushed to the campaign dashboard (influence-stats)
# as a new row (or an update to an existing one). CAMPAIGN_DASHBOARD_URL is
# that service's base URL; leave blank to disable the sync (the signature
# still records locally and a backfill can retry). No campaign-id mapping is
# needed — campaigns are already synced FROM the dashboard (see
# CAMPAIGNS_API_BASE above), so creator.campaign_id already matches the
# dashboard's own campaign id.
# CAMPAIGN_DASHBOARD_API_KEY must match the dashboard's DEAL_STUDIO_API_KEY —
# it's sent as the x-api-key header.
# To backfill contracts that were signed BEFORE this was configured, either:
#   • run once:  npm run sync:dashboard           (add --dry-run to preview), or
#   • trigger over HTTP (no shell needed):
#       POST /api/bot/sync-contracts-to-dashboard?dryRun=true   with x-bot-token: OUTREACH_BOT_TOKEN
#     (drop dryRun to actually push). Set OUTREACH_BOT_TOKEN to use this route.
CAMPAIGN_DASHBOARD_URL=
CAMPAIGN_DASHBOARD_API_KEY=
# Optional: per-request timeout for campaign-dashboard calls (ms). Default 15000.
CAMPAIGN_DASHBOARD_TIMEOUT_MS=

# --- Bot API auth (inbound) -----------------------------------------------
# Shared secret that protects the /api/bot/* endpoints — used by the campaigns
# dashboard (influence-stats) to fetch per-creator contract URLs for the
# "Contract submission" column. Set to a random string and mirror it as
# OUTREACH_BOT_TOKEN on the influence-stats service. If unset the bot endpoints
# return 503.
OUTREACH_BOT_TOKEN=

# Set to 1/true to log negotiation emails instead of sending them (dry-run).
DRY_RUN=

# --- Offer Portal (old-creator negotiation) -------------------------------
# "Old" creators (those who already did a DIFFERENT campaign, per the Creator
# Database) negotiate on a hosted offer page instead of over email. The admin's
# approved offer is minted as an offer-portal offer and its /o/:token link is
# delivered over email + WhatsApp + iMessage; accept/decline/counter happen on
# the page. Offer links are built from PUBLIC_BASE_URL (set at the top of this
# file) as {PUBLIC_BASE_URL}/o/{token}.
#
# Every channel below skips gracefully when its key is absent, so the flow is
# safe to run partially configured (e.g. WhatsApp only). All are replicated from
# the Influence-CDB-portal offer system.

# Email channel — transactional offer + confirmation emails via Resend's REST
# API (no SDK dependency). Leave RESEND_API_KEY blank to skip email sends.
RESEND_API_KEY=
# From address for offer-portal emails. Falls back to EMAIL_FROM, then a default.
OFFER_EMAIL_FROM=INFLUENCE <offers@useinfluence.xyz>

# WhatsApp channel — AiSensy. AISENSY_CAMPAIGN_NAME is the pre-approved template
# (params: First Name, Brand Name, Offer Link, Expiry Date).
AISENSY_API_KEY=
AISENSY_CAMPAIGN_NAME=offer_outreach
# Optional overrides for the AiSensy endpoints.
AISENSY_API_URL=
AISENSY_TEXT_API_URL=
# Optional shared secret to authenticate the inbound webhook POST /webhook/aisensy.
AISENSY_WEBHOOK_SECRET=
# Optional fallback template (a Meta-approved AiSensy "utility" template with a
# single body param {{1}}). When a free-form session reply fails — e.g. it's
# outside Meta's 24h customer-service window — the same text is re-sent through
# this template so a delayed thank-you / reply still reaches the creator. Leave
# blank to just report the failure instead.
AISENSY_SESSION_CAMPAIGN=

# iMessage channel — Linq Partner API v3 (https://linqapp.com). Sends blue-bubble
# iMessages: POST {IMESSAGE_API_URL} with Authorization: Bearer {IMESSAGE_API_KEY}
# and a chats/parts JSON body. Your SANDBOX token selects the sandbox environment
# (same base URL). Leave IMESSAGE_API_KEY blank to skip iMessage sends.
# IMESSAGE_API_URL defaults to Linq's /chats endpoint when unset.
IMESSAGE_API_URL=https://api.linqapp.com/api/partner/v3/chats
IMESSAGE_API_KEY=
# The Linq sender number outbound iMessages come from — E.164 with the leading
# "+" (your sandbox-assigned number). Required for sends.
IMESSAGE_FROM_NUMBER=
# Linq HMAC signing secret for the inbound webhook (POST /webhook/imessage). When
# set, inbound POSTs are signature-verified; leave blank to accept unsigned posts
# (sandbox). The verifier accepts both the Standard Webhooks and X-Linq-Signature
# schemes — confirm which your Linq dashboard uses.
IMESSAGE_WEBHOOK_SECRET=

# Offer economics. OFFER_CURRENCY is the currency offers are priced in (ISO
# 4217). OFFER_EXPIRY_DAYS is how long an offer stays open. The counter-offer
# CPM knobs (COUNTER_CPM_TOLERANCE, MAX_CPM_MULTIPLE, COUNTER_STRATEGY,
# COUNTER_RATE_TOLERANCE_PCT) mirror the Influence-CDB-portal defaults.
OFFER_CURRENCY=USD
OFFER_EXPIRY_DAYS=7
COUNTER_CPM_TOLERANCE=1.5
MAX_CPM_MULTIPLE=2
COUNTER_STRATEGY=midpoint
COUNTER_RATE_TOLERANCE_PCT=0.15

# New-vs-old segmentation cache TTL (ms). A creator's segment is re-checked
# against the Creator Database once it's older than this. Default 24h.
SEGMENT_TTL_MS=86400000
