# Server
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# Host that serves the open-tracking pixel and the /unsubscribe endpoints.
# In production set this to an HTTPS subdomain of your sending domain
# (e.g. https://track.useinfluence.xyz) so the pixel + unsubscribe link
# look aligned with the From: domain — a cross-domain remote-image fetch on
# cold mail is a spam signal. Falls back to PUBLIC_BASE_URL if unset.
TRACKING_BASE_URL=

# Secret used to HMAC the per-recipient unsubscribe tokens in the
# List-Unsubscribe header and footer link. Must be set in production —
# without it, the unsubscribe header is omitted (emails still send, but
# Gmail/Yahoo won't show the "Easy Unsubscribe" pip). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
UNSUBSCRIBE_SECRET=

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/influence_outreach

# Google OAuth (create at https://console.cloud.google.com/)
# Scopes required: https://www.googleapis.com/auth/gmail.send, gmail.readonly
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Sender identity (must match the authorized Google account)
SENDER_EMAIL=jennifer@useinfluence.xyz
SENDER_NAME=Jennifer

# Scheduler
FOLLOWUP_DELAY_HOURS=48
SCHEDULER_INTERVAL_MINUTES=15

# Pre-send email verification (syntax + DNS/MX). On by default; undeliverable
# scraped addresses are skipped and flagged 'invalid_email' instead of bouncing.
# Set EMAIL_VERIFY=0 to disable.
EMAIL_VERIFY=1
# Per-creator pacing between bulk outreach sends (ms). Jittered ±20%.
SEND_PACING_MS=60000

# Upstream brands + campaigns source
# GET https://campaigns.influence.technology/api/bot/campaigns with x-bot-token header
CAMPAIGNS_API_BASE=https://campaigns.influence.technology
CAMPAIGNS_API_TOKEN=

# Optional: Instagram sessionid cookie from Jennifer's logged-in browser.
# Required to read business_email (the "Email" button data) for most profiles.
# Get it from Chrome: DevTools -> Application -> Cookies -> instagram.com -> sessionid
IG_SESSION_COOKIE=

# --- Instantly.ai (hybrid sending) ----------------------------------------
# API key from https://app.instantly.ai/app/settings/integrations
INSTANTLY_API_KEY=
# UUID of the campaign leads are added to for outreach + follow-up sending.
# Copy from the campaign URL in the Instantly dashboard.
INSTANTLY_CAMPAIGN_ID=
# Optional: HMAC secret to verify Instantly webhook signatures.
# Set this in the Instantly webhook config to reject forged payloads.
INSTANTLY_WEBHOOK_SECRET=

# --- Creator negotiation ---------------------------------------------------
# Claude is used ONLY to (a) understand plain-text replies and (b) write the
# emails. Offer numbers are 100% formula (see pricing.js).
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Pricing formula constants. effectiveCpm = TARGET_CPM * (1 - RISK_BUFFER).
TARGET_CPM=15
RISK_BUFFER=0.20
BONUS_PERCENTAGE=0.20
NUM_VIDEOS=2

# Admin approval gate: no offer email sends until an admin approves an offer.
REQUIRE_OFFER_APPROVAL=true

# Negotiation follow-ups: bump after N idle days, at most this many, then CLOSED.
NEGOTIATION_FOLLOWUP_DAYS=2
NEGOTIATION_MAX_FOLLOWUPS=2

# Brand / manager / posting cadence. The campaign's own brand_name wins over
# BRAND_NAME; MANAGER_NAME defaults to SENDER_NAME.
BRAND_NAME=
MANAGER_NAME=
# Posting cadence / timeline guidance, e.g. "1-2 videos per week". Claude (or
# the deterministic fallback) derives an approximate "all videos posted by"
# date from this cadence + today's date + the number of videos in the deal —
# it is NOT a literal date. CONTENT_CADENCE wins if both are set.
CAMPAIGN_DEADLINE=1-2 videos per week
CONTENT_CADENCE=

# Set to 1/true to log negotiation emails instead of sending them (dry-run).
DRY_RUN=
