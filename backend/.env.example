# Server
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/influence_outreach

# Scheduler — how often the negotiation poller runs (outreach + follow-ups
# are sent by Instantly on its own schedule).
SCHEDULER_INTERVAL_MINUTES=5

# Pre-send email verification (syntax + DNS/MX). On by default; undeliverable
# scraped addresses are skipped and flagged 'invalid_email' instead of being
# pushed into Instantly. Set EMAIL_VERIFY=0 to disable.
EMAIL_VERIFY=1
# Per-creator pacing between bulk lead-add calls to Instantly (ms). Jittered ±20%.
SEND_PACING_MS=60000

# Signatory shown in outreach + follow-up email bodies (the {SENDER_NAME}
# substitution in the built-in templates). Also used as a fallback for
# MANAGER_NAME if that isn't set.
SENDER_NAME=Jennifer

# Upstream brands + campaigns source
# GET https://campaigns.influence.technology/api/bot/campaigns with x-bot-token header
CAMPAIGNS_API_BASE=https://campaigns.influence.technology
CAMPAIGNS_API_TOKEN=

# Optional: Instagram sessionid cookie from Jennifer's logged-in browser.
# Required to read business_email (the "Email" button data) for most profiles.
# Get it from Chrome: DevTools -> Application -> Cookies -> instagram.com -> sessionid
IG_SESSION_COOKIE=

# --- Instantly.ai (email sender) ------------------------------------------
# All outreach, follow-ups, and negotiation replies go through Instantly.
# API key from https://app.instantly.ai/app/settings/integrations
INSTANTLY_API_KEY=
# Fallback Instantly campaign UUID. Each dashboard campaign can set its own
# Instantly campaign ID (Campaign settings → "Instantly campaign ID") so every
# brand uses its own outreach copy + follow-up sequence. This env value is used
# only for campaigns that haven't been mapped. Copy a UUID from the campaign URL
# in the Instantly dashboard.
INSTANTLY_CAMPAIGN_ID=
# HMAC secret to verify Instantly webhook signatures. Set this in the
# Instantly webhook config to reject forged payloads.
INSTANTLY_WEBHOOK_SECRET=
# Optional: per-request timeout for Instantly API calls (ms). Default 15000.
INSTANTLY_TIMEOUT_MS=
# Optional fallback sending mailbox (eaccount) for threaded negotiation replies.
# Normally the mailbox is captured automatically from each reply webhook
# (email_account). This is only used for replies received before that field was
# stored. Must be a connected Instantly account, e.g. jennifer@frominfluence.com
INSTANTLY_EACCOUNT=

# --- Creator negotiation ---------------------------------------------------
# Claude is used ONLY to (a) understand plain-text replies and (b) write the
# emails. Offer numbers are 100% formula (see pricing.js).
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Pricing formula constants. effectiveCpm = TARGET_CPM * (1 - RISK_BUFFER).
TARGET_CPM=15
RISK_BUFFER=0.20
BONUS_PERCENTAGE=0.20
NUM_VIDEOS=2

# Admin approval gate: no offer email sends until an admin approves an offer.
REQUIRE_OFFER_APPROVAL=true

# Negotiation follow-ups: bump after N idle days, at most this many, then CLOSED.
NEGOTIATION_FOLLOWUP_DAYS=2
NEGOTIATION_MAX_FOLLOWUPS=2

# Brand / manager / posting cadence. The campaign's own brand_name wins over
# BRAND_NAME. MANAGER_NAME is the signatory shown in negotiation emails.
BRAND_NAME=
MANAGER_NAME=Jennifer
# Posting cadence / timeline guidance, e.g. "1-2 videos per week". Claude (or
# the deterministic fallback) derives an approximate "all videos posted by"
# date from this cadence + today's date + the number of videos in the deal —
# it is NOT a literal date. CONTENT_CADENCE wins if both are set.
CAMPAIGN_DEADLINE=1-2 videos per week
CONTENT_CADENCE=

# --- Continuous reply learning ---------------------------------------------
# The negotiation model "learns" by collecting labeled (creator inbound →
# manager reply) pairs into the reply_examples table and replaying the most
# relevant ones as few-shot examples in every Claude prompt. Two feeds:
#
# 1. Delegate replies — every reply a human sends from the Delegate window is
#    labeled and stored immediately, so the same doubt/question stops landing
#    in the Delegate queue. Set LEARN_FROM_DELEGATE=0 to disable.
LEARN_FROM_DELEGATE=1
# 2. Mailbox harvest — every LEARN_HARVEST_HOURS the scheduler sweeps the
#    connected mailbox (jennifer@useinfluence.xyz) through the Instantly API,
#    pairs each creator message with the next manager reply, labels the pair
#    with Claude, and stores it. 0 disables the scheduled sweep (the manual
#    `npm run learn:harvest` CLI still works).
LEARN_HARVEST_HOURS=24
# Cap on mailbox emails scanned per harvest run (newest first).
LEARN_HARVEST_MAX_EMAILS=500
# The mailbox address whose messages count as "ours" when pairing threads.
# Falls back to INSTANTLY_EACCOUNT when unset.
SENDER_EMAIL=jennifer@useinfluence.xyz

# --- Creator Contracts -----------------------------------------------------
# When a creator accepts, a unique contract is generated and emailed as
# {PUBLIC_BASE_URL}/contract/{token} (PUBLIC_BASE_URL is set at the top of this
# file). In production, set PUBLIC_BASE_URL=https://campaigns.influence.technology
# — that service proxies /contract/:token, /contract.js and /api/contracts/*
# straight through to this backend (see its OUTREACH_BASE_URL env var), so the
# link the creator gets carries the campaigns.influence.technology domain while
# this backend still does all the actual work. This backend also still serves
# /contract/:token (and the legacy /contracts/:token) directly, so a bare
# PUBLIC_BASE_URL pointing at this service's own origin works too (e.g. local
# dev, or if the proxy isn't set up yet).
#
# Creator Database sync: after a contract is signed the creator + contract are
# pushed to the Creator-Database service (which dedups by email → instagram →
# name). CREATOR_DB_URL is that service's base URL; leave blank to disable the
# sync (the signature still records locally and a scheduler pass can retry).
# CREATOR_DB_API_KEY must match the Creator DB's INTERNAL_API_KEY — it's sent as
# the x-api-key header.
CREATOR_DB_URL=
CREATOR_DB_API_KEY=
# Optional: per-request timeout for Creator-DB calls (ms). Default 15000.
CREATOR_DB_TIMEOUT_MS=

# --- Bot API auth (inbound) -----------------------------------------------
# Shared secret that protects the /api/bot/* endpoints — used by the campaigns
# dashboard (influence-stats) to fetch per-creator contract URLs for the
# "Contract submission" column. Set to a random string and mirror it as
# OUTREACH_BOT_TOKEN on the influence-stats service. If unset the bot endpoints
# return 503.
OUTREACH_BOT_TOKEN=

# Set to 1/true to log negotiation emails instead of sending them (dry-run).
DRY_RUN=
